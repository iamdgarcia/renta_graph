# RentaGraph — Environment Variables
#
# Python pipeline only (compiler + scraper).
# The web app (app/) is fully BYOK — no server-side API keys needed.

# Required to run the LLM compiler (python pipeline.py compile)
OPENAI_API_KEY=sk-...

# Optional: override the wiki output directory (default: app/content/wiki)
# WIKI_DIR=app/content/wiki


LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT="renta-ai"

ANTHROPIC_API_KEY=<your-anthropic-api-key>
